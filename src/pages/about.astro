---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About"
  description="About Wheeler Works and Max Wheeler."
>
  <h1 class="text-2xl font-medium tracking-tight text-foreground">About</h1>
  <div
    class="mt-6 space-y-4 text-foreground/80 leading-relaxed max-w-prose"
  >
    <p>
      Wheeler Works is a public workshop for the small tools I build for
      myself. Some of them are CLI utilities, some are local apps, some are
      half-finished experiments.
    </p>
    <p>
      Nothing here is a product. Things ship when they work for me and get
      archived when they don't.
    </p>
  </div>
</BaseLayout>
