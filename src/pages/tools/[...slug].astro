---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("tools");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const dateLabel = entry.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const statusStyles = {
  active:
    "bg-emerald-50 text-emerald-700 dark:bg-emerald-950/40 dark:text-emerald-300",
  beta: "bg-amber-50 text-amber-700 dark:bg-amber-950/40 dark:text-amber-300",
  archived:
    "bg-neutral-100 text-neutral-500 dark:bg-neutral-900 dark:text-neutral-400",
} as const;

const statusLabels = {
  active: "Available",
  beta: "In beta",
  archived: "Archived",
} as const;
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article>
    <a
      href="/"
      class="text-xs text-neutral-500 hover:text-neutral-900 dark:hover:text-neutral-100"
    >
      ← All tools
    </a>

    <header class="mt-4 mb-8">
      <div class="flex items-start gap-4">
        {
          entry.data.icon ? (
            <Image
              src={entry.data.icon}
              alt=""
              width={64}
              height={64}
              class="w-16 h-16 rounded-lg object-cover shrink-0 border border-neutral-200 dark:border-neutral-800"
            />
          ) : (
            <div
              role="presentation"
              class="w-16 h-16 rounded-lg shrink-0 bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 flex items-center justify-center text-neutral-500 dark:text-neutral-400 font-medium text-2xl select-none"
            >
              {entry.data.title.charAt(0).toUpperCase()}
            </div>
          )
        }
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-2">
            <span
              class={
                "px-2 py-0.5 text-xs rounded-full " +
                statusStyles[entry.data.status]
              }
            >
              {statusLabels[entry.data.status]}
            </span>
            <time class="text-xs text-neutral-500">{dateLabel}</time>
          </div>
          <h1 class="text-3xl font-medium tracking-tight">
            {entry.data.title}
          </h1>
          <p class="mt-2 text-neutral-600 dark:text-neutral-400 text-lg">
            {entry.data.description}
          </p>
        </div>
      </div>

      <div class="mt-4 flex flex-wrap items-center gap-2 text-xs">
        {
          entry.data.platforms.map((p) => (
            <span class="px-2 py-0.5 rounded-full border border-neutral-300 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300">
              {p}
            </span>
          ))
        }
        {
          entry.data.tags.length > 0 && (
            <span class="text-neutral-500 dark:text-neutral-400">
              {entry.data.tags.join(" · ")}
            </span>
          )
        }
        {
          entry.data.githubUrl && (
            <a
              href={entry.data.githubUrl}
              class="ml-auto text-neutral-700 dark:text-neutral-300 underline underline-offset-2 hover:opacity-70"
              rel="noopener"
              target="_blank"
            >
              GitHub ↗
            </a>
          )
        }
      </div>
    </header>

    <div
      class="prose prose-neutral dark:prose-invert max-w-none prose-headings:font-medium prose-headings:tracking-tight prose-pre:bg-neutral-900 prose-pre:text-neutral-100"
    >
      <Content />
    </div>
  </article>
</BaseLayout>
