---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Badge from "@wheeler-works/ui-astro/Badge.astro";
import Prose from "@wheeler-works/ui-astro/Prose.astro";

export async function getStaticPaths() {
  const entries = await getCollection("tools");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const dateLabel = entry.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const statusVariant = {
  active: "success",
  beta: "warning",
  archived: "outline",
} as const;

const statusLabels = {
  active: "Available",
  beta: "In beta",
  archived: "Archived",
} as const;
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article>
    <a
      href="/"
      class="text-xs text-muted-foreground hover:text-foreground"
    >
      ← All tools
    </a>

    <header class="mt-4 mb-8">
      <div class="flex items-start gap-4">
        {
          entry.data.icon ? (
            <Image
              src={entry.data.icon}
              alt=""
              width={64}
              height={64}
              class="w-16 h-16 rounded-lg object-cover shrink-0 border border-border"
            />
          ) : (
            <div
              role="presentation"
              class="w-16 h-16 rounded-lg shrink-0 bg-muted text-muted-foreground border border-border flex items-center justify-center font-medium text-2xl select-none"
            >
              {entry.data.title.charAt(0).toUpperCase()}
            </div>
          )
        }
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-2">
            <Badge variant={statusVariant[entry.data.status]}>
              {statusLabels[entry.data.status]}
            </Badge>
            <time class="text-xs text-muted-foreground">{dateLabel}</time>
          </div>
          <h1 class="text-3xl font-medium tracking-tight text-foreground">
            {entry.data.title}
          </h1>
          <p class="mt-2 text-muted-foreground text-lg">
            {entry.data.description}
          </p>
        </div>
      </div>

      <div class="mt-4 flex flex-wrap items-center gap-2 text-xs">
        {
          entry.data.platforms.map((p) => (
            <Badge variant="outline">{p}</Badge>
          ))
        }
        {
          entry.data.tags.length > 0 && (
            <span class="text-muted-foreground">
              {entry.data.tags.join(" · ")}
            </span>
          )
        }
        {
          entry.data.githubUrl && (
            <a
              href={entry.data.githubUrl}
              class="ml-auto text-foreground underline underline-offset-2 hover:opacity-70"
              rel="noopener"
              target="_blank"
            >
              GitHub ↗
            </a>
          )
        }
      </div>
    </header>

    <Prose>
      <Content />
    </Prose>
  </article>
</BaseLayout>
