---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Prose from "@wheeler-works/ui-astro/Prose.astro";

export async function getStaticPaths() {
  const entries = await getCollection("tools");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article>
    <a
      href="/"
      class="text-xs text-muted-foreground hover:text-foreground"
    >
      ← All tools
    </a>

    <header class="mt-4 mb-8">
      <div class="flex items-start gap-4">
        {
          entry.data.icon ? (
            <Image
              src={entry.data.icon}
              alt=""
              width={64}
              height={64}
              class="w-16 h-16 rounded-lg object-cover shrink-0 border border-border"
            />
          ) : (
            <div
              role="presentation"
              class="w-16 h-16 rounded-lg shrink-0 bg-muted text-muted-foreground border border-border flex items-center justify-center font-medium text-2xl select-none"
            >
              {entry.data.title.charAt(0).toUpperCase()}
            </div>
          )
        }
        <div class="flex-1 min-w-0">
          <h1 class="text-3xl font-medium tracking-tight text-foreground">
            {entry.data.title}
          </h1>
          <p class="mt-2 text-muted-foreground text-lg">
            {entry.data.description}
          </p>
        </div>
      </div>
    </header>

    <div class="tool-body">
      <Prose>
        <Content />
      </Prose>
    </div>
  </article>
</BaseLayout>

<style>
  /* Keep screenshots — especially tall phone captures — from dominating the
     page. Landscape shots are unaffected (already shorter than the cap). Images
     and their captions share one paragraph, so centering the paragraph does both. */
  .tool-body :global(p:has(img)) {
    text-align: center;
  }
  .tool-body :global(img) {
    display: block;
    margin-inline: auto;
    max-width: 100%;
    max-height: 56rem;
    width: auto;
    height: auto;
  }
</style>
