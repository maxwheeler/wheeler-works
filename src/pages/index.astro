---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ToolGrid, { type ToolCard } from "../components/ToolGrid";
import HomeIntro from "../content/home-intro.mdx";

const entries = await getCollection("tools");

const tools: ToolCard[] = entries
  .map((entry) => ({
    slug: entry.id,
    title: entry.data.title,
    description: entry.data.description,
    iconSrc: entry.data.icon?.src ?? null,
    tags: entry.data.tags,
    platforms: entry.data.platforms,
    status: entry.data.status,
    date: entry.data.date.toISOString(),
    featured: entry.data.featured,
    githubUrl: entry.data.githubUrl,
  }))
  .sort((a, b) => b.date.localeCompare(a.date));

const allTags = Array.from(new Set(tools.flatMap((t) => t.tags))).sort((a, b) =>
  a.localeCompare(b),
);
---

<BaseLayout
  title="Wheeler Works"
  description="A workshop of small tools by Max Wheeler."
>
  <section
    class="mb-12 prose prose-neutral dark:prose-invert max-w-none prose-headings:font-medium prose-headings:tracking-tight prose-h1:text-2xl prose-h1:mb-2"
  >
    <HomeIntro />
  </section>

  <ToolGrid client:load tools={tools} allTags={allTags} />
</BaseLayout>
