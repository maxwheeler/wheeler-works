---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ToolGrid, { type ToolCard } from "../components/ToolGrid";

const entries = await getCollection("tools");

const tools: ToolCard[] = entries
  .map((entry) => ({
    slug: entry.id,
    title: entry.data.title,
    description: entry.data.description,
    tags: entry.data.tags,
    status: entry.data.status,
    date: entry.data.date.toISOString(),
    featured: entry.data.featured,
    githubUrl: entry.data.githubUrl,
  }))
  .sort((a, b) => b.date.localeCompare(a.date));

const allTags = Array.from(
  new Set(tools.flatMap((t) => t.tags)),
).sort((a, b) => a.localeCompare(b));
---

<BaseLayout
  title="Wheeler Works"
  description="A workshop of small tools by Max Wheeler."
>
  <section class="mb-12">
    <h1 class="text-2xl font-medium tracking-tight">Wheeler Works</h1>
    <p class="mt-2 text-neutral-600 dark:text-neutral-400 max-w-prose">
      A personal workshop of small tools — things I build to scratch my own
      itches.
    </p>
  </section>

  <ToolGrid client:load tools={tools} allTags={allTags} />
</BaseLayout>
