---
const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="border-b border-border">
  <div class="mx-auto max-w-3xl px-6 py-5 flex items-center justify-between">
    <a
      href="/"
      class="flex items-center gap-2 text-base font-medium tracking-tight text-foreground hover:opacity-70"
    >
      <img
        src="/icon.png"
        alt=""
        aria-hidden="true"
        width="32"
        height="32"
        class="w-8 h-8 rounded-md"
      />
      Wheeler Works
    </a>
    <nav class="flex gap-6 text-sm">
      <a
        href="/"
        class:list={[
          "text-foreground hover:opacity-70",
          isActive("/") && "font-medium underline underline-offset-4",
        ]}
      >
        Home
      </a>
    </nav>
  </div>
</header>
